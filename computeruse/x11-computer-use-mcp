#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = ["fastmcp", "pyautogui", "python-xlib", "Pillow"]
# ///
"""
Computer-Use MCP Server (X11 / pyautogui backend)
Provides screenshot and input tools for Claude coding agents using pyautogui.
Screenshots use python-xlib + Pillow directly to avoid pyscreeze's at-import
tool detection. All input uses pyautogui. No external CLI tools required.
"""

import io
import os

# Ensure DISPLAY and XAUTHORITY are set before pyautogui/mouseinfo connects to X at import time.
DISPLAY = os.environ.get("DISPLAY", ":0")
os.environ["DISPLAY"] = DISPLAY

# An empty Xauthority file is valid and means "no auth required" (correct for virtual displays).
_xauth = os.environ.get("XAUTHORITY", os.path.expanduser("~/.Xauthority"))
if not os.path.exists(_xauth):
    open(_xauth, "wb").close()
os.environ["XAUTHORITY"] = _xauth

import pyautogui
from fastmcp import FastMCP
from fastmcp.utilities.types import Image
from Xlib import X
from Xlib.display import Display as XDisplay
from Xlib.protocol import event as xevent
from PIL import Image as PILImage, ImageDraw, ImageFont

# Disable the move-to-corner abort for unattended/agent use
pyautogui.FAILSAFE = False

server = FastMCP(
    "computer-use",
    instructions="""
This server controls a 1920x1080 X11 desktop. All coordinates are actual screen pixels.

## Coordinate accuracy — read this first

Screenshots are returned as full 1920x1080 images but your viewer renders them smaller.
DO NOT estimate click coordinates by visual position in the rendered image — you will be
off by a significant factor and click the wrong place.

Always use one of these two approaches to find accurate coordinates before clicking:

1. **screenshot_grid** — overlays labelled grid lines at 100px intervals directly on the
   screenshot. Read the nearest grid labels and interpolate. The labels ARE the actual
   screen coordinates to pass to click().

2. **screenshot_region(x, y, width, height, scale=2)** — crops and magnifies a region.
   Coordinates are still in screen space: actual_x = x + pixel_x_in_zoomed_image / scale.
   Use this to zoom in on a small or dense area after narrowing down the location with
   screenshot_grid.

## Recommended workflow

1. Call screenshot_grid() to get a labelled overview.
2. Read off the grid coordinates near your target element.
3. If the area is small/dense, call screenshot_region() to zoom in and refine.
4. Call click() with the coordinates you read from the grid/region image.

## Window tools

- list_windows() — returns all managed windows with id, title, x, y, width, height.
- activate_window(id) — raises and focuses a window (use before screenshot_window).
- screenshot_window(id) — captures just that window's client area.
""",
)


def _capture_screen() -> tuple[bytes, int, int]:
    """Capture root window via python-xlib + Pillow, bypassing pyscreeze entirely.
    Returns (jpeg_bytes, screen_width, screen_height).
    """
    disp = XDisplay(DISPLAY)
    root = disp.screen().root
    geom = root.get_geometry()
    raw = root.get_image(0, 0, geom.width, geom.height, X.ZPixmap, 0xFFFFFFFF)
    img = PILImage.frombytes("RGB", (geom.width, geom.height), raw.data, "raw", "BGRX")
    buf = io.BytesIO()
    img.save(buf, format="JPEG", quality=85)
    return buf.getvalue(), geom.width, geom.height


@server.tool()
def screenshot(save_path: str | None = None):
    """Take a screenshot of the display. Returns JPEG image.

    Args:
        save_path: Optional path to save the screenshot (e.g., "/tmp/screenshot.jpg")
    """
    image_bytes, sw, sh = _capture_screen()

    if save_path:
        with open(save_path, "wb") as f:
            f.write(image_bytes)

    return [Image(data=image_bytes, format="jpeg"),
            f"Screen: {sw}x{sh}px — image pixels are actual screen coordinates"]


@server.tool()
def get_screen_size() -> dict:
    """Return the screen width and height in pixels."""
    disp = XDisplay(DISPLAY)
    root = disp.screen().root
    geom = root.get_geometry()
    return {"width": geom.width, "height": geom.height}


@server.tool()
def list_windows() -> list[dict]:
    """List all managed windows with id, title, x, y, width, height."""
    disp = XDisplay(DISPLAY)
    root = disp.screen().root
    net_client_list = disp.intern_atom("_NET_CLIENT_LIST")
    prop = root.get_full_property(net_client_list, X.AnyPropertyType)
    if prop is None:
        return []
    results = []
    net_wm_name = disp.intern_atom("_NET_WM_NAME")
    wm_name = disp.intern_atom("WM_NAME")
    for wid in prop.value:
        try:
            win = disp.create_resource_object("window", wid)
            tp = win.get_full_property(net_wm_name, X.AnyPropertyType)
            if tp and tp.value:
                title = bytes(tp.value).decode("utf-8", errors="replace")
            else:
                tp2 = win.get_full_property(wm_name, X.AnyPropertyType)
                title = bytes(tp2.value).decode("latin-1", errors="replace") if tp2 and tp2.value else ""
            geom = win.get_geometry()
            trans = root.translate_coords(win, 0, 0)
            results.append({
                "id": int(wid),
                "title": title,
                "x": trans.x,
                "y": trans.y,
                "width": geom.width,
                "height": geom.height,
            })
        except Exception:
            pass
    return results


@server.tool()
def activate_window(window_id: int) -> str:
    """Raise and focus a window by its numeric window ID.

    Args:
        window_id: Window ID as returned by list_windows
    """
    disp = XDisplay(DISPLAY)
    root = disp.screen().root
    win = disp.create_resource_object("window", window_id)
    net_active_window = disp.intern_atom("_NET_ACTIVE_WINDOW")
    evt = xevent.ClientMessage(
        window=win,
        client_type=net_active_window,
        data=(32, [2, X.CurrentTime, 0, 0, 0]),
    )
    root.send_event(evt, event_mask=X.SubstructureRedirectMask | X.SubstructureNotifyMask)
    disp.flush()
    return f"Activated window {window_id}"


@server.tool()
def screenshot_window(window_id: int, save_path: str | None = None):
    """Take a screenshot of a specific window.

    Args:
        window_id: Window ID as returned by list_windows
        save_path: Optional path to save the screenshot (e.g., "/tmp/window.jpg")
    """
    disp = XDisplay(DISPLAY)
    root = disp.screen().root
    win = disp.create_resource_object("window", window_id)
    geom = win.get_geometry()
    trans = root.translate_coords(win, 0, 0)
    x, y, w, h = trans.x, trans.y, geom.width, geom.height
    raw = root.get_image(x, y, w, h, X.ZPixmap, 0xFFFFFFFF)
    img = PILImage.frombytes("RGB", (w, h), raw.data, "raw", "BGRX")
    buf = io.BytesIO()
    img.save(buf, format="JPEG", quality=85)
    image_bytes = buf.getvalue()
    if save_path:
        with open(save_path, "wb") as f:
            f.write(image_bytes)
    return [Image(data=image_bytes, format="jpeg"),
            f"Window at screen ({x},{y}), size {w}x{h}px — "
            f"screen_x = {x} + img_x, screen_y = {y} + img_y"]



def _draw_grid(img: PILImage.Image, spacing: int) -> PILImage.Image:
    """Overlay a coordinate grid with labels onto a PIL image."""
    img = img.copy()
    draw = ImageDraw.Draw(img, "RGBA")
    w, h = img.size
    try:
        font = ImageFont.truetype("/usr/share/fonts/truetype/dejavu/DejaVuSansMono.ttf", 14)
    except Exception:
        font = ImageFont.load_default()

    for x in range(0, w, spacing):
        draw.line([(x, 0), (x, h)], fill=(255, 255, 0, 100), width=1)
        draw.text((x + 2, 2), str(x), fill=(255, 255, 0, 220), font=font)
    for y in range(0, h, spacing):
        draw.line([(0, y), (w, y)], fill=(255, 255, 0, 100), width=1)
        draw.text((2, y + 2), str(y), fill=(255, 255, 0, 220), font=font)
    return img


@server.tool()
def screenshot_grid(spacing: int = 100, save_path: str | None = None):
    """Take a screenshot with a coordinate grid overlaid.

    Grid lines and labels show actual screen pixel coordinates, making it
    easy to identify the x,y position of any element without guessing.

    Args:
        spacing: Pixels between grid lines (default: 100)
        save_path: Optional path to save the screenshot (e.g., "/tmp/grid.jpg")
    """
    image_bytes, sw, sh = _capture_screen()
    img = PILImage.open(io.BytesIO(image_bytes)).convert("RGBA")
    img = _draw_grid(img, spacing).convert("RGB")
    buf = io.BytesIO()
    img.save(buf, format="JPEG", quality=85)
    image_bytes = buf.getvalue()
    if save_path:
        with open(save_path, "wb") as f:
            f.write(image_bytes)
    return [Image(data=image_bytes, format="jpeg"),
            f"Screen: {sw}x{sh}px — grid labels are actual screen coordinates"]


@server.tool()
def screenshot_region(x: int, y: int, width: int, height: int, scale: int = 2, save_path: str | None = None):
    """Capture and magnify a region of the screen.

    Crops to the given rectangle and scales it up, making it easier to
    identify exact coordinates within dense or small UI areas.
    The coordinates in the returned image are still in original screen space
    (divide pixel position in the returned image by scale to get screen coords).

    Args:
        x: Left edge of the region in screen pixels
        y: Top edge of the region in screen pixels
        width: Width of the region in screen pixels
        height: Height of the region in screen pixels
        scale: Zoom multiplier (default: 2)
        save_path: Optional path to save the screenshot (e.g., "/tmp/region.jpg")
    """
    image_bytes, sw, sh = _capture_screen()
    img = PILImage.open(io.BytesIO(image_bytes))
    img = img.crop((x, y, x + width, y + height))
    if scale != 1:
        img = img.resize((width * scale, height * scale), PILImage.NEAREST)
    buf = io.BytesIO()
    img.save(buf, format="JPEG", quality=85)
    image_bytes = buf.getvalue()
    if save_path:
        with open(save_path, "wb") as f:
            f.write(image_bytes)
    return [Image(data=image_bytes, format="jpeg"),
            f"Region ({x},{y}) {width}x{height}px at {scale}x zoom. Screen: {sw}x{sh}px — "
            f"screen_x = {x} + img_x/{scale}, screen_y = {y} + img_y/{scale}"]


@server.tool()
def click(x: int, y: int, button: str = "left") -> str:
    """Click at x,y coordinates.

    Args:
        x: X coordinate
        y: Y coordinate
        button: Mouse button - left, right, or middle (default: left)
    """
    pyautogui.click(x, y, button=button)
    return "Clicked"


@server.tool()
def double_click(x: int, y: int) -> str:
    """Double-click at x,y coordinates.

    Args:
        x: X coordinate
        y: Y coordinate
    """
    pyautogui.doubleClick(x, y)
    return "Double-clicked"


@server.tool()
def type_text(text: str, delay: int = 50) -> str:
    """Type text using the keyboard.

    Args:
        text: Text to type
        delay: Delay between keystrokes in ms (default: 50)
    """
    pyautogui.write(text, interval=delay / 1000)
    return "Typed"


@server.tool()
def mouse_move(x: int, y: int) -> str:
    """Move mouse to x,y coordinates.

    Args:
        x: X coordinate
        y: Y coordinate
    """
    pyautogui.moveTo(x, y)
    return "Mouse moved"


@server.tool()
def mouse_down(x: int, y: int, button: str = "left") -> str:
    """Press mouse button down at x,y.

    Args:
        x: X coordinate
        y: Y coordinate
        button: Mouse button - left, right, or middle (default: left)
    """
    pyautogui.mouseDown(x, y, button=button)
    return "Mouse down"


@server.tool()
def mouse_up(x: int, y: int, button: str = "left") -> str:
    """Release mouse button at x,y.

    Args:
        x: X coordinate
        y: Y coordinate
        button: Mouse button - left, right, or middle (default: left)
    """
    pyautogui.mouseUp(x, y, button=button)
    return "Mouse up"


@server.tool()
def scroll(x: int, y: int, delta_x: int, delta_y: int) -> str:
    """Scroll at x,y coordinates.

    Args:
        x: X coordinate
        y: Y coordinate
        delta_x: Horizontal scroll amount (negative = left, positive = right)
        delta_y: Vertical scroll amount (negative = up, positive = down)
    """
    if delta_y != 0:
        # pyautogui scroll: positive = up, so negate to match caller convention
        pyautogui.scroll(-delta_y, x=x, y=y)
    if delta_x != 0:
        pyautogui.hscroll(delta_x, x=x, y=y)
    return "Scrolled"


@server.tool()
def key_down(key: str) -> str:
    """Press a key down (without releasing).

    Args:
        key: pyautogui key name (e.g., 'shift', 'ctrl', 'a', 'enter')
    """
    pyautogui.keyDown(key)
    return "Key down"


@server.tool()
def key_up(key: str) -> str:
    """Release a key.

    Args:
        key: pyautogui key name (e.g., 'shift', 'ctrl')
    """
    pyautogui.keyUp(key)
    return "Key up"


@server.tool()
def key_press(key: str) -> str:
    """Press and release a key or key combination.

    Args:
        key: pyautogui key name or '+'-joined combo (e.g., 'enter', 'escape', 'f1', 'ctrl+c')
    """
    keys = key.split("+")
    if len(keys) > 1:
        pyautogui.hotkey(*keys)
    else:
        pyautogui.press(key)
    return "Key pressed"


@server.tool()
def drag(from_x: int, from_y: int, to_x: int, to_y: int) -> str:
    """Drag from one point to another.

    Args:
        from_x: Start X coordinate
        from_y: Start Y coordinate
        to_x: End X coordinate
        to_y: End Y coordinate
    """
    pyautogui.moveTo(from_x, from_y)
    pyautogui.dragTo(to_x, to_y, button="left")
    return "Dragged"


if __name__ == "__main__":
    server.run()
